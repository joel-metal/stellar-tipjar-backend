# Test environment configuration
TEST_DATABASE_URL=postgres://postgres:password@localhost/tipjar_test
DATABASE_URL=postgres://postgres:password@localhost/tipjar_test

# Stellar configuration for tests
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Server configuration
PORT=8001

# Redis (optional for tests)
REDIS_URL=redis://127.0.0.1:6379

# Rate limiting (relaxed for tests)
RATE_LIMIT_PER_SECOND=100
RATE_LIMIT_BURST_SIZE=200
RATE_LIMIT_WRITE_PER_SECOND=50
RATE_LIMIT_WRITE_BURST_SIZE=100

# Test-specific settings
RUST_LOG=debug
TEST_TIMEOUT_SECONDS=30